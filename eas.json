{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://dev.api.awslearn.app",
        "EXPO_PUBLIC_CLOUDFRONT_URL": "https://dev.cdn.awslearn.app"
      },
      "channel": "development"
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://dev.api.awslearn.app",
        "EXPO_PUBLIC_CLOUDFRONT_URL": "https://dev.cdn.awslearn.app"
      },
      "channel": "development-simulator"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a -Pexpo.gif.enabled=false"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://katalyst-supabase-proxy.schinchli5801.workers.dev/functions/v1",
        "EXPO_PUBLIC_CLOUDFRONT_URL": "https://cdn.awslearn.app"
      }
    },
    "preview-stable": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a,x86_64 -Pexpo.gif.enabled=false -Pexpo.webp.enabled=true"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://katalyst-supabase-proxy.schinchli5801.workers.dev/functions/v1",
        "EXPO_PUBLIC_CLOUDFRONT_URL": "https://cdn.awslearn.app"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://katalyst-supabase-proxy.schinchli5801.workers.dev/functions/v1",
        "EXPO_PUBLIC_CLOUDFRONT_URL": "https://cdn.awslearn.app"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "macos-15-xcode-26"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "TODO: your@apple.id",
        "ascAppId": "TODO: 1234567890",
        "appleTeamId": "TODO: XXXXXXXXXX"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
