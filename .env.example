# ──────────────────────────────────────────────────────────────────────────────
# AWS GenAI Prep — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before shipping.
# EXPO_PUBLIC_* values are bundled into the client at build time.
# Never commit .env — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── AWS ───────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_API_URL=https://dev.api.awslearn.app
EXPO_PUBLIC_CLOUDFRONT_URL=https://dev.cdn.awslearn.app

# Cognito — get from AWS Console → Cognito → User Pools
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
EXPO_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AdMob ─────────────────────────────────────────────────────────────────────
# App IDs go in app.json plugins (already configured with Google test IDs).
# Ad unit IDs go here — get them from your AdMob console.

# iOS Ad Units
EXPO_PUBLIC_ADMOB_IOS_BANNER=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# Android Ad Units
EXPO_PUBLIC_ADMOB_ANDROID_BANNER=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# ── Private (GitHub Secrets only — never in .env) ────────────────────────────
# EXPO_TOKEN                  EAS authentication token
# AWS_ACCESS_KEY_ID           For CDK/Lambda deployments
# AWS_SECRET_ACCESS_KEY       For CDK/Lambda deployments
# APPLE_ID                    For EAS Submit (iOS)
# APPLE_APP_SPECIFIC_PASSWORD For EAS Submit (iOS)
# GOOGLE_SERVICE_ACCOUNT_KEY  For EAS Submit (Android)
